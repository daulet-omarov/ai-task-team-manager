APP_PORT=8080
APP_URL=0.0.0.0:8080
APP_BASE_URL=http://localhost:8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=myapp
DB_SSLMODE=disable

JWT_SECRET=change-me-to-strong-secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

ALLOWED_ORIGINS=http://localhost:5173

# S3 / DO Spaces (leave S3_BUCKET empty to use local ./uploads storage)
S3_ENDPOINT=https://blr1.digitaloceanspaces.com
S3_REGION=blr1
S3_ACCESS_KEY=your-spaces-access-key
S3_SECRET_KEY=your-spaces-secret-key
S3_BUCKET=your-bucket-name
S3_PUBLIC_URL=https://your-bucket-name.blr1.digitaloceanspaces.com
